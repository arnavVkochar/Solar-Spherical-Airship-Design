<PropertyList>

 <!-- The hull. -->
 <path>airship_components.ac</path>
 <offsets>
  <!-- x/y/z == back/right/up -->
  <x-m> 0.0 </x-m>
  <y-m> 0.0 </y-m>
  <z-m> 0.0 </z-m>
      <heading-deg>90</heading-deg>
    <pitch-deg>0</pitch-deg>   <!-- adjust if gondola points sideways -->
    <roll-deg>0</roll-deg>    
 </offsets>


 

 <!-- LOD for the model as a whole =========================================-->
 <animation>
  <type>range</type>
  <min-m>0</min-m>
  <max-m>15000</max-m>
 </animation>


</PropertyList>
