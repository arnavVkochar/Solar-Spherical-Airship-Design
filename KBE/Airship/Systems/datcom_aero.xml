<?xml version="1.0"?>

 <aerodynamics>

  <function name="aero/envelope-lift-force-tweak-factor">
   <value> 0.0 </value>
  </function>
  <function name="aero/envelope-moment-tweak-factor">
   <value> 0.0 </value>
  </function>
  <function name="aero/vtail-moment-tweak-factor">
   <value> 0.0 </value>
  </function>

  <!-- Envelope pressure (kept for Weigh_Off system reference). -->
  <function name="aero/envelope/pressure-psf">
   <difference>
    <property> buoyant_forces/gas-cell/pressure-psf </property>
    <property> atmosphere/P-psf </property>
   </difference>
  </function>

  <!--
  === Wind / body frame helpers =====================================
  These decompose the total aerodynamic force direction for the DRAG
  axis projection. Required by the drag axis function below.
  -->
  <function name="aero/tmp/wx">
   <product>
    <cos><property> aero/alpha-rad </property></cos>
    <cos><property> aero/beta-rad  </property></cos>
   </product>
  </function>
  <function name="aero/tmp/wy">
   <product>
    <cos><property> aero/alpha-rad </property></cos>
    <sin><property> aero/beta-rad  </property></sin>
   </product>
  </function>
  <function name="aero/tmp/wz">
   <sin><property> aero/alpha-rad </property></sin>
  </function>
  <function name="aero/tmp/h_wy_wz">
   <pow>
    <sum>
     <pow><property> aero/tmp/wy </property><value>2.0</value></pow>
     <pow><property> aero/tmp/wz </property><value>2.0</value></pow>
    </sum>
    <value>0.5</value>
   </pow>
  </function>

  <!-- Total angle between envelope axis and relative wind (= AoA for sphere). -->
  <function name="aero/envelope-aoa-mag-rad">
   <max>
    <value>0.0</value>
    <acos><property> aero/tmp/wx </property></acos>
   </max>
  </function>
  <function name="aero/envelope-aoa-mag-deg">
   <product>
    <value> 57.29578 </value>
    <property> aero/envelope-aoa-mag-rad </property>
   </product>
  </function>

  <axis name="DRAG">

   <function name="aero/force/D_env_aoa">
    <description>
     Pressure drag from spherical envelope.
     CD_sphere ≈ 0.47 at zero AoA (smooth sphere, sub-critical Re).
     As AoA increases the body presents the same frontal area but
     the wake grows; the table below models the mild increase toward
     90° and the symmetric reduction to ~0.47 at 180°.
     Reference area = pi*r^2 (frontal disc) = Sw-sqft.
    </description>
    <product>
     <property>aero/qbar-psf</property>
     <property>metrics/Sw-sqft</property>
     <!-- CD sphere vs. total incidence angle -->
     <table>
      <independentVar lookup="row">aero/envelope-aoa-mag-deg</independentVar>

      <tableData>
    0.0   0.156
    15.0   0.156
    30.0   0.156
    45.0   0.156
    60.0   0.156
    75.0   0.156
    90.0   0.156
   105.0   0.156
   120.0   0.156
   135.0   0.156
   150.0   0.156
   165.0   0.156
   180.0   0.156
      </tableData>
     </table>
    </product>
   </function>

   <function name="aero/force/D_car">
    <product>
     <property>aero/qbar-psf</property>
     <property>metrics/Sw-sqft</property>
     <value> 0.100 </value>  <!-- Sref scaling -->
     <value> 0.011 </value>  <!-- Parasitic CD of gondola/rigging -->
    </product>
   </function>

  </axis>

  <axis name="SIDE">

   <function name="aero/force/Y_sphere">
    <description>
     Side force — zero for a symmetric sphere at all beta.
     (Drag is isotropic; there is no preferred cross-flow direction.)
    </description>
    <value> 0.0 </value>
   </function>

  </axis>


  <axis name="LIFT">

   <function name="aero/force/L_sphere">
    <description>
     Lift — zero for a symmetric sphere at all alpha.
    </description>
    <value> 0.0 </value>
   </function>

  </axis>


  <axis name="ROLL">

   <function name="aero/moment/Cl_sphere_damp">
    <description>
     Viscous roll damping for sphere (very small).
     Clp estimated ~-0.01 for smooth sphere (much less than finned body).
     Using 1% of the NT07 fin value as a placeholder.
    </description>
    <product>
     <property>aero/qbar-psf</property>
     <property>metrics/Sw-sqft</property>
     <property>metrics/bw-ft</property>
     <property>aero/bi2vel</property>
     <property>velocities/p-aero-rad_sec</property>
     <value> -0.05 </value>  <!-- Clp sphere, tune as needed -->
    </product>
   </function>

  </axis>


  <axis name="PITCH">

   <function name="aero/moment/Cmq_envelope">
    <description>
     Pitch damping from envelope viscous wake (per radian/sec).
     Body-only DATCOM value for alpha = 0 retained from NT07 model.
     This is the dominant pitch damping source with no fins.
     Increase magnitude if sim shows underdamped pitch oscillation.
    </description>
    <product>
     <property>aero/qbar-psf</property>
     <property>metrics/Sw-sqft</property>
     <property>metrics/cbarw-ft</property>
     <property>aero/ci2vel</property>
     <property>velocities/q-aero-rad_sec</property>
     <value> -0.05 </value>  
    </product>
   </function>

  </axis>

  <axis name="YAW">

   <function name="aero/moment/Cnr_envelope">
    <description>
     Yaw damping from envelope viscous wake (per radian/sec).
     Assumed equal to Cmq (sphere is symmetric in all axes).
    </description>
    <product>
     <property>aero/qbar-psf</property>
     <property>metrics/Sw-sqft</property>
     <property>metrics/cbarw-ft</property>
     <property>aero/ci2vel</property>
     <property>velocities/r-aero-rad_sec</property>
     <value> -0.05 </value>  
    </product>
   </function>

  </axis>

 </aerodynamics>