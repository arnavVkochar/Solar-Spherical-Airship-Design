 <!-- ═══════════════════════════════════════════
      SPACE — zero vertical thrust
 ═══════════════════════════════════════════════ -->

 <key n="32">
  <name>Space</name>
  <desc>Zero vertical thrust</desc>
  <binding>
   <command>nasal</command>
   <script>
    setprop("/fdm/jsbsim/fcs/vertical-thrust-cmd-norm", 0.0);
    gui.popupTip("Vertical thrust zeroed.");
   </script>
  </binding>
 </key>

 <!-- ═══════════════════════════════════════════
      EMERGENCY STOP  (C / c)
      Zeros all engines
 ═══════════════════════════════════════════════ -->

 <key n="67">
  <name>C</name>
  <desc>Stop ALL thrust</desc>
  <binding>
   <command>nasal</command>
   <script>
    setprop("/fdm/jsbsim/fcs/engine0-cmd-norm",         0.0);
    setprop("/fdm/jsbsim/fcs/engine1-cmd-norm",         0.0);
    setprop("/fdm/jsbsim/fcs/vertical-thrust-cmd-norm", 0.0);
    gui.popupTip("ALL thrust stopped.");
   </script>
  </binding>
 </key>

 <key n="99">
  <name>c</name>
  <desc>Stop ALL thrust</desc>
  <binding>
   <command>nasal</command>
   <script>
    setprop("/fdm/jsbsim/fcs/engine0-cmd-norm",         0.0);
    setprop("/fdm/jsbsim/fcs/engine1-cmd-norm",         0.0);
    setprop("/fdm/jsbsim/fcs/vertical-thrust-cmd-norm", 0.0);
    gui.popupTip("ALL thrust stopped.");
   </script>
  </binding>
 </key>

 <!-- ═══════════════════════════════════════════
      ALTITUDE HOLD  (h / H)
 ═══════════════════════════════════════════════ -->

 <key n="104">
  <name>h</name>
  <desc>Altitude hold ON</desc>
  <binding>
   <command>nasal</command>
   <script>airship.alt_hold_start();</script>
  </binding>
 </key>

 <key n="72">
  <name>H</name>
  <desc>Altitude hold OFF</desc>
  <binding>
   <command>nasal</command>
   <script>airship.alt_hold_stop();</script>
  </binding>
 </key>



 <!-- ═══════════════════════════════════════════
      MOORING RELEASE  (Y)
 ═══════════════════════════════════════════════ -->

 <key n="89">
  <name>Y</name>
  <desc>Release mooring</desc>
  <binding>
   <command>nasal</command>
   <script>Airship.release_mooring();</script>
  </binding>
</key>

 <!-- ═══════════════════════════════════════════
      GAS VALVE  (F open / f close)
 ═══════════════════════════════════════════════ -->

 <key n="70">
  <name>F</name>
  <desc>Open gas valve — vent helium</desc>
  <binding>
   <command>nasal</command>
   <script>
    gui.popupTip("Gas valve OPEN — venting helium!");
    setprop("/fdm/jsbsim/buoyant_forces/gas-cell[0]/valve_open", 1.0);
   </script>
  </binding>
 </key>

 <key n="102">
  <name>f</name>
  <desc>Close gas valve</desc>
  <binding>
   <command>nasal</command>
   <script>
    gui.popupTip("Gas valve closed.");
    setprop("/fdm/jsbsim/buoyant_forces/gas-cell[0]/valve_open", 0.0);
   </script>
  </binding>
 </key>

<key n="109">
 <name>m</name>
 <desc>Drop all ballast.</desc>
 <binding>
  <command>nasal</command>
  <script>Airship.drop_ballast();</script>
 </binding>
</key>

</PropertyList>