<?xml version="1.0" encoding="UTF-8"?>
<!--
  Keyboard bindings for Spherical Solar Airship.

  CONTROL SUMMARY
  ───────────────────────────────────────────────
  A              Engine 0 (PORT)  forward
  a              Engine 0 (PORT)  reverse
  D              Engine 1 (STBD)  forward
  d              Engine 1 (STBD)  reverse
  W / S          Vertical thrust UP / DOWN
  Space          Zero vertical thrust
  C / c          Stop ALL thrust
  H              Altitude hold ON
  Shift+H        Altitude hold OFF
  B / b          Ballonet inflate / deflate
  N / n          Ballonet neutral
  F              Open gas valve (vent helium)
  f              Close gas valve
  Y              Release mooring
  ───────────────────────────────────────────────
-->
<PropertyList>

 <!-- ═══════════════════════════════════════════
      ENGINE 0 (PORT horizontal)  —  A / a
      A = full forward   a = full reverse
 ═══════════════════════════════════════════════ -->

 <key n="65">
  <name>A</name>
  <desc>Engine 0 PORT forward</desc>
  <repeatable type="bool">true</repeatable>
  <binding>
   <command>nasal</command>
     <script>
     var v = airship._clamp(
          (getprop("/fdm/jsbsim/fcs/engine0-cmd-norm") or 0) + 0.05,
          -1.0, 1.0);
     setprop("/fdm/jsbsim/fcs/engine0-cmd-norm", v);
     gui.popupTip("Engine 0: " ~ int(v * 100) ~ "%");
     </script>
  </binding>
 </key>

 <key n="97">
  <name>a</name>
  <desc>Engine 0 PORT reverse</desc>
  <repeatable type="bool">true</repeatable>
  <binding>
   <command>nasal</command>
     <script>
     var v = airship._clamp(
          (getprop("/fdm/jsbsim/fcs/engine0-cmd-norm") or 0) - 0.05,
          -1.0, 1.0);
     setprop("/fdm/jsbsim/fcs/engine0-cmd-norm", v);
     gui.popupTip("Engine 0: " ~ int(v * 100) ~ "%");
     </script>
  </binding>
 </key>

