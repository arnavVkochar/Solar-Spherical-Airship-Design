 <!-- ═══════════════════════════════════════════
      VERTICAL THRUST  (W / S)
 ═══════════════════════════════════════════════ -->

 <key n="87">
  <name>W</name>
  <desc>Vertical thrust UP</desc>
  <repeatable type="bool">true</repeatable>
  <binding>
   <command>nasal</command>
   <script>
    var v = airship._clamp(
        (getprop("/fdm/jsbsim/fcs/vertical-thrust-cmd-norm") or 0) + 0.05,
        -1.0, 1.0);
    setprop("/fdm/jsbsim/fcs/vertical-thrust-cmd-norm", v);
   </script>
  </binding>
 </key>

 <key n="83">
  <name>S</name>
  <desc>Vertical thrust DOWN</desc>
  <repeatable type="bool">true</repeatable>
  <binding>
   <command>nasal</command>
   <script>
    var v = airship._clamp(
